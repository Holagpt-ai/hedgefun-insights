{
  "rewrites": [
    {
      "source": "/stocks/:ticker",
      "destination": "https://hedgefun-seo.vercel.app/stocks/:ticker"
    },
    {
      "source": "/etf/:ticker",
      "destination": "https://hedgefun-seo.vercel.app/etf/:ticker"
    },
    {
      "source": "/ipos/:ticker",
      "destination": "https://hedgefun-seo.vercel.app/ipos/:ticker"
    },
    {
      "source": "/sitemap-index",
      "destination": "https://hedgefun-seo.vercel.app/sitemap-index"
    },
    {
      "source": "/sitemap-stocks/:path*",
      "destination": "https://hedgefun-seo.vercel.app/sitemap-stocks/:path*"
    },
    {
      "source": "/sitemap-etfs/:path*",
      "destination": "https://hedgefun-seo.vercel.app/sitemap-etfs/:path*"
    },
    {
      "source": "/sitemap-ipos/:path*",
      "destination": "https://hedgefun-seo.vercel.app/sitemap-ipos/:path*"
    },
    {
      "source": "/sitemap-static",
      "destination": "https://hedgefun-seo.vercel.app/sitemap-static"
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://qrsmjctuhikoxgzxouhf.supabase.co/functions/v1/sitemap"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        }
      ]
    },
    {
      "source": "/ads.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        }
      ]
    }
  ]
}
